                },
                "createdAt": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "externalURL": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "moderatedAt": {
                    "type": "string"
                },
                "slug": {
                    "type": "string"
                },
